OPENROUTER_API_KEY=your_openrouter_key_here
OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
AKVAN_PROVIDER=openrouter
AKVAN_MODEL=openai/gpt-4o-mini
AKVAN_OPENROUTER_API_MODE=responses  # or: chat
AKVAN_APPROVAL_MODE=ask  # ask, deny, or off
AKVAN_APPROVAL_TIMEOUT=60
AKVAN_TERMINAL_TIMEOUT=120
# For OpenAI Codex provider, set:
# AKVAN_PROVIDER=openai-codex
# AKVAN_MODEL=gpt-5.5
# AKVAN_CODEX_AUTH_MODE=cli  # default; or: api-key
# Akvan checks $CODEX_HOME/auth.json, then ~/.codex/auth.json, then ~/codex/auth.json
# For DeepSeek provider, set:
# AKVAN_PROVIDER=deepseek
# AKVAN_MODEL=deepseek-chat
# AKVAN_DEEPSEEK_THINKING=enabled  # default; or: disabled
# AKVAN_DEEPSEEK_REASONING_EFFORT=high  # optional: low, medium, high, max
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # optional override

# Telegram gateway (akvan gateway)
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# Web tools (akvan tools)
# AKVAN_WEB_SEARCH_BACKEND=searxng  # or: ddgs
# SEARXNG_URL=http://localhost:8080
# AKVAN_WEB_EXTRACT_BACKEND=firecrawl
# FIRECRAWL_API_URL=http://localhost:3002
# FIRECRAWL_API_KEY=optional_for_self_hosted
# AKVAN_WEB_EXTRACT_SUMMARY_MODEL=openai/gpt-4o-mini
# AKVAN_GATEWAY_STREAM_EDIT_INTERVAL=0.8
# AKVAN_GATEWAY_STREAM_TRANSPORT=auto
# AKVAN_GATEWAY_RICH_MESSAGES=true
# AKVAN_GATEWAY_RICH_DRAFTS=true
